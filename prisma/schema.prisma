generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Employee time tracking (clock in/out) ---

model Employee {
  id        String   @id @default(uuid())
  name      String
  role      String   // SUPER_ADMIN | EMPLOYEE
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  passcode   EmployeePasscode?
  sessions   EmployeeSession[]
  timeEntries TimeEntry[]
  orders     Order[]

  @@map("employees")
}

model EmployeePasscode {
  employeeId        String   @unique
  employee          Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  passcodeHash      String
  passcodeUpdatedAt DateTime @default(now())

  @@map("employee_passcodes")
}

model EmployeeSession {
  id        String   @id @default(uuid())
  employeeId String
  employee  Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([employeeId])
  @@map("employee_sessions")
}

model TimeEntry {
  id         String    @id @default(uuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  clockInAt  DateTime
  clockOutAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([employeeId, createdAt])
  @@index([employeeId, clockInAt])
  @@index([clockInAt])
  @@map("time_entries")
}

// --- Menu management ---

model MenuItem {
  id          String      @id @default(uuid())
  name        String
  basePrice   Int
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  addOnGroups AddOnGroup[]

  @@index([isActive, name])
  @@map("menu_items")
}

model AddOnGroup {
  id            String       @id @default(uuid())
  menuItemId    String
  menuItem      MenuItem     @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  name          String
  minSelectable Int          @default(0)
  maxSelectable Int          @default(0)
  sortOrder     Int          @default(0)
  options       AddOnOption[]

  @@index([menuItemId])
  @@map("addon_groups")
}

model AddOnOption {
  id          String     @id @default(uuid())
  addOnGroupId String
  addOnGroup  AddOnGroup @relation(fields: [addOnGroupId], references: [id], onDelete: Cascade)
  name        String
  price       Int        @default(0)
  sortOrder   Int        @default(0)

  @@index([addOnGroupId])
  @@map("addon_options")
}

// --- Payment method catalog (Super Admin configurable) ---

model PaymentMethod {
  id        String   @id @default(uuid())
  code      String   @unique
  label     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
  @@map("payment_methods")
}

// --- Company settings (single row) ---

model CompanySetting {
  id                       String   @id @default("default")
  companyName              String
  registerNumber           String?
  contactNumber            String?
  address                  String?
  email                    String?
  thermalPaperWidth         String?
  defaultPaymentMethodCode  String?
  thermalPrinterQueueName   String?
  updatedAt                 DateTime @updatedAt

  @@map("company_settings")
}

// --- Orders ---

model Order {
  id                    String            @id @default(uuid())
  sequence              Int               @unique @default(autoincrement())
  /** Client-supplied label for offline replay (e.g. OFF-AB12); when null, API uses C{sequence}. */
  publicOrderNumber     String?           @map("public_order_number")
  employeeId            String
  employee              Employee          @relation(fields: [employeeId], references: [id])
  subtotalCents         Int               // sum of lines before discount
  discountCents         Int               @default(0)
  totalCents            Int               // max(0, subtotalCents - discountCents)
  paymentMethod         String            // catalog code: CASH | CARD | OTHER | …
  paymentMethodDetail   String?           // sub-method code when OTHER (e.g. TNG)
  tenderCents           Int?              // cash tender amount (cents)
  changeDueCents        Int?              // max(0, tenderCents - totalCents) for cash
  status                String            @default("PENDING") // PENDING | COMPLETED | CANCELLED | REFUNDED
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  lines                 OrderLine[]
  auditEvents           OrderAuditEvent[]

  @@index([createdAt])
  @@index([createdAt, status])
  @@index([employeeId])
  @@map("orders")
}

model OrderAuditEvent {
  id              String   @id @default(uuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  action          String   // REFUND | CHANGE_PAYMENT | …
  actorEmployeeId String
  payload         Json?
  createdAt       DateTime @default(now())

  @@index([orderId])
  @@map("order_audit_events")
}

model OrderLine {
  id           String           @id @default(uuid())
  orderId      String
  order        Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId   String
  menuItemName String
  basePrice    Int
  quantity     Int
  addOns       OrderLineAddon[]

  @@index([orderId])
  @@map("order_lines")
}

model OrderLineAddon {
  id          String    @id @default(uuid())
  orderLineId String
  orderLine   OrderLine @relation(fields: [orderLineId], references: [id], onDelete: Cascade)
  optionId    String
  optionName  String
  price       Int

  @@index([orderLineId])
  @@map("order_line_addons")
}
