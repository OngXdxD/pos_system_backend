# PostgreSQL connection URL
# Replace user, password, host, port, and database with your values
DATABASE_URL="postgresql://user:password@localhost:5432/pos_db?schema=public"

# Optional: API server port (default 3000)
PORT=3000

# JWT secret for auth tokens (required in production)
JWT_SECRET=your-secret-key-change-in-production

# Comma-separated browser origins allowed for CORS (no trailing slashes)
# CORS_ORIGINS=https://pos.goderecollectible.com,http://localhost:5173
#
# Optional: allow any origin (dev only; do not use in production)
# CORS_ALLOW_ALL=true
